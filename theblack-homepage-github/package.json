{
  "name": "theblack-homepage",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "node scripts/build.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit -p tsconfig.json",
    "cf:dev": "npm run build && wrangler pages dev dist"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^8.0.12"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "wrangler": "^4.90.0"
  }
}
